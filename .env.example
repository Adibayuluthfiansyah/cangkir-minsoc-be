# ========================================
# ENVIRONMENT CONFIGURATION
# ========================================
# Template untuk environment variables
# Copy file ini ke .env dan isi dengan nilai yang sesuai
# PENTING: JANGAN commit file .env ke git!

# ========================================
# APPLICATION
# ========================================
NODE_ENV=production
PORT=3000
API_PREFIX=api

# ========================================
# DATABASE (PostgreSQL)
# ========================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:PASSWORD_ANDA@localhost:5432/cangkir_minisoccer?schema=public"

# Detail Database (untuk monitoring/backup scripts)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=PASSWORD_DATABASE_ANDA
DB_NAME=cangkir_minisoccer

# CATATAN KEAMANAN DATABASE:
# - Gunakan password minimal 16 karakter
# - Kombinasi huruf besar, kecil, angka, dan simbol
# - Jangan gunakan password default (postgres, admin, dll)
# - Contoh generate password: openssl rand -base64 24

# ========================================
# JWT AUTHENTICATION
# ========================================
# Secret key untuk signing JWT tokens
JWT_SECRET=GANTI_DENGAN_SECRET_KEY_YANG_KUAT_MINIMAL_32_KARAKTER

# Durasi token berlaku (contoh: 7d, 24h, 30m)
JWT_EXPIRATION=7d

# CATATAN KEAMANAN JWT:
# - JWT_SECRET harus minimal 32 karakter
# - Gunakan string random yang kuat
# - Generate dengan: openssl rand -base64 48
# - JANGAN gunakan string yang mudah ditebak
# - Ganti JWT_SECRET jika terjadi security breach

# ========================================
# REDIS (Caching & Distributed Locking)
# ========================================
# IMPORTANT: Aplikasi menggunakan Upstash Redis REST API
# untuk reliability dan compatibility dengan cloud deployments

# Upstash Redis REST API (RECOMMENDED untuk production)
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN_HERE

# CATATAN UPSTASH REDIS:
# - Free tier: 10,000 requests/day (cukup untuk small-medium traffic)
# - Connection via HTTPS (no firewall issues)
# - Setup: https://console.upstash.com/redis
# - Copy REST URL dan Token dari dashboard
# - Compatible dengan Railway, Vercel, Azure, dll

# Alternative: Native Redis (untuk local development)
# Uncomment jika menggunakan local Redis server:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_TLS=false

# CATATAN KEAMANAN REDIS:
# - UPSTASH_REDIS_REST_TOKEN adalah credential sensitive
# - Jangan commit token ke git
# - Rotate token jika terjadi exposure
# - Monitor usage di Upstash dashboard

# ========================================
# CORS & FRONTEND
# ========================================
# URL frontend aplikasi
FRONTEND_URL=https://domain-anda.com

# Daftar origins yang diizinkan (pisahkan dengan koma)
CORS_ORIGINS=https://domain-anda.com,https://www.domain-anda.com

# CATATAN KEAMANAN CORS:
# - Jangan gunakan wildcard (*) di production
# - List semua domain yang legitimate
# - Gunakan HTTPS untuk production

# ========================================
# ADMIN WHATSAPP
# ========================================
# Nomor WhatsApp admin (format: 62xxx tanpa +)
ADMIN_WHATSAPP=6281234567890

# ========================================
# DEFAULT ADMIN ACCOUNT
# ========================================
# Kredensial admin yang dibuat otomatis saat seeding
ADMIN_DEFAULT_USERNAME=superadmin
ADMIN_DEFAULT_PASSWORD=GANTI_PASSWORD_INI_SEGERA
ADMIN_DEFAULT_FULLNAME=Administrator
ADMIN_DEFAULT_PHONE=6281234567890

# CATATAN KEAMANAN ADMIN:
# - SEGERA ganti password setelah deployment pertama
# - Password minimal 12 karakter
# - Kombinasi huruf besar, kecil, angka, dan simbol
# - Jangan gunakan password yang mudah ditebak
# - Sebaiknya hapus ADMIN_DEFAULT_PASSWORD setelah setup awal

# ========================================
# EMAIL CONFIGURATION (Optional)
# ========================================
# Uncomment dan isi jika ingin menggunakan email notification
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USER=email-anda@gmail.com
# MAIL_PASSWORD=app_password_gmail_anda
# MAIL_FROM="Cangkir Mini Soccer <noreply@minisoccer.id>"

# CATATAN EMAIL:
# - Untuk Gmail, gunakan App Password (bukan password akun)
# - Enable 2FA dan generate App Password di akun Google
# - Untuk production, pertimbangkan menggunakan service email (SendGrid, AWS SES)

# ========================================
# BOOKING RULES
# ========================================
# Minimum jam booking per transaksi
MIN_BOOKING_HOURS=1

# Maximum jam booking per transaksi
MAX_BOOKING_HOURS=8

# Berapa hari ke depan customer bisa booking
BOOKING_ADVANCE_DAYS=30

# Berapa jam sebelumnya customer bisa cancel booking
CANCELLATION_HOURS=24

# ========================================
# DEPLOYMENT CHECKLIST
# ========================================
# Sebelum deploy ke production, pastikan:
# [ ] Semua PASSWORD diganti dengan nilai yang kuat
# [ ] JWT_SECRET diganti dengan random string (min 32 char)
# [ ] REDIS_PASSWORD sudah diset
# [ ] NODE_ENV=production
# [ ] CORS_ORIGINS hanya list domain yang legitimate
# [ ] Database backup strategy sudah disetup
# [ ] HTTPS/SSL sudah dikonfigurasi
# [ ] Firewall rules sudah dikonfigurasi
# [ ] Log rotation sudah disetup
# [ ] Health check endpoint sudah ditest

# ========================================
# PRODUCTION SECURITY TIPS
# ========================================
# 1. Generate JWT_SECRET kuat:
#    openssl rand -base64 48
#
# 2. Generate password database:
#    openssl rand -base64 24
#
# 3. Set file permission .env:
#    chmod 600 .env
#
# 4. Backup database secara berkala:
#    pg_dump -U postgres cangkir_minisoccer > backup.sql
#
# 5. Monitor Redis memory usage:
#    redis-cli info memory
#
# 6. Check application health:
#    curl https://domain-anda.com/api/health
#
# 7. Rotate secrets secara berkala (setiap 90 hari)
#
# 8. Review logs untuk suspicious activity:
#    tail -f logs/application.log
